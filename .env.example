# ─────────────────────────────────────────────────────────
#  HireSense AI — Environment Configuration
#  Copy this file to .env and fill in your values
# ─────────────────────────────────────────────────────────

# Environment
ENVIRONMENT=development   # development | staging | production
DEBUG=false

# ── Database ──────────────────────────────────────────────
POSTGRES_USER=hiresense
POSTGRES_PASSWORD=hiresense_secret_change_me
POSTGRES_DB=hiresense_db
DATABASE_URL=postgresql+asyncpg://hiresense:hiresense_secret_change_me@postgres:5432/hiresense_db

# ── Redis ─────────────────────────────────────────────────
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/1
CELERY_RESULT_BACKEND=redis://redis:6379/2

# ── Security ──────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-this-in-production-min-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=14
TOKEN_ISSUER=hiresense-ai
TOKEN_AUDIENCE=hiresense-users
PASSWORD_HASH_ROUNDS=200000
INITIAL_ADMIN_EMAIL=admin@hiresense.ai
INITIAL_ADMIN_PASSWORD=ChangeMe123!
INITIAL_ADMIN_FULL_NAME=HireSense Admin
INITIAL_ADMIN_ROLE=admin
RATE_LIMIT_REQUESTS_PER_MINUTE=120
RATE_LIMIT_UPLOADS_PER_MINUTE=10
RATE_LIMIT_BURST=20

# ── AI Model ──────────────────────────────────────────────
MODEL_PATH=/app/models/resume_scorer.pt
MODEL_VERSION=v1.0.0
DEVICE=cuda  # cuda | cpu
MODEL_PORT=8001
EMBEDDING_MODEL_NAME=sentence-transformers/all-MiniLM-L6-v2
VECTOR_BACKEND=faiss  # memory | faiss | chroma
VECTOR_INDEX_PATH=/app/data/vector.index
VECTOR_METADATA_PATH=/app/data/vector_meta.json

# ── LLM (Ollama) ─────────────────────────────────────────
OLLAMA_URL=http://ollama:11434
LLM_MODEL=mistral:7b          # mistral:7b | phi3:mini | llama3:8b
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1024
LLM_TIMEOUT=120

# ── File Upload ───────────────────────────────────────────
UPLOAD_DIR=/app/uploads
MAX_FILE_SIZE_MB=10
ALLOWED_EXTENSIONS=["pdf","docx"]

# ── Frontend ──────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000

# ── Celery Flower ─────────────────────────────────────────
FLOWER_USER=admin
FLOWER_PASSWORD=admin123

# ── Monitoring ────────────────────────────────────────────
GRAFANA_PASSWORD=admin123

# ── Kaggle (for dataset download) ─────────────────────────
# Place your kaggle.json at ~/.kaggle/kaggle.json
# OR set these env vars:
# KAGGLE_USERNAME=your_kaggle_username
# KAGGLE_KEY=your_kaggle_api_key

# ── HuggingFace (alternative dataset source) ──────────────
HF_TOKEN=          # Optional: for gated models
HF_DATASET=ahmedheakl/resume-atlas

# ── CORS ─────────────────────────────────────────────────
CORS_ORIGINS=["http://localhost:3000","http://localhost:80","https://yourdomain.com"]
